# SanFran iLab Brand API — Environment Variables
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# API Key para autenticação Bearer. Se vazio, modo aberto (apenas dev).
API_KEY=

# Caminho customizado para brand.json (opcional)
# BRAND_JSON_PATH=/caminho/custom/brand.json

LOG_LEVEL=info

# === LLM (Anthropic) — para POST /brand/generate-copy ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# === Instagram (Meta Graph API) — para POST /brand/publish-instagram ===
# Access token de página com permissões: instagram_basic + instagram_content_publish
META_ACCESS_TOKEN=
# ID numérico da conta Instagram Business/Creator
IG_USER_ID=

# === Story renderer (Playwright) ===
# Caminho customizado para o brandbook (opcional)
# INDEX_HTML_PATH=/caminho/index.html
