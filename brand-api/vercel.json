{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["brand.json", "api/lib/assets-catalog.json"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/server.js" }
  ],
  "env": {
    "RENDER_DISABLED": "1",
    "NODE_ENV": "production"
  }
}
